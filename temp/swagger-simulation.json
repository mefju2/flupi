            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Requests.RunScenarioRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Requests.RunScenarioRequest"
              }
            },
            "application/*+json": {
              "schema": {
