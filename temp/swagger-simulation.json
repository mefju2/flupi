          "App Lifecycle"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/arconq/v1.0/handlers/MessageHandlerWrapper": {
      "post": {
        "tags": [
          "Message Handlers"
        ],
        "parameters": [
          {
            "name": "X-Routing-Id",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/components/schemas/System.Text.Json.Nodes.JsonNode"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
