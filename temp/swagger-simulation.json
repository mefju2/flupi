              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Responses.StopScenarioResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/test-scenarios/current/action": {
      "post": {
        "tags": [
          "TestScenario"
