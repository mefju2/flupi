        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Responses.RunScenarioResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Responses.RunScenarioResponse"
