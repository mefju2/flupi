      "delete": {
        "tags": [
          "TestScenario"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Responses.StopScenarioResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WES.SimulationEngine.Contracts.Responses.StopScenarioResponse"
