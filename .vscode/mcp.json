{
	"servers": {
		"svelte": {
			"url": "https://mcp.svelte.dev/mcp"
		},
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"]
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"-p",
				"3.13",
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--context",
				"ide",
				"--project",
				"${workspaceFolder}"
			]
		},
		"ck": {
			"command": "ck",
			"args": ["--serve"],
			"cwd": "${workspaceFolder}"
		}
	}
}
