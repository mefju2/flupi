{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flupi",
  "version": "0.1.7",
  "identifier": "com.mateuszmichno.flupi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Flupi",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0RDc0NTc2Q0M4ODJCMDQKUldRRUs0ak1ka1hYZElzM3FmWmQ1b3VXZ3c4YlVkODcvSVpHTzRWNmdZVklTZnNoTGNWMmFLdHEK",
      "endpoints": [
        "https://github.com/mefju2/flupi/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
